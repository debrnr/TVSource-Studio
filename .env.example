# TVSource Studio 环境变量配置示例
# 复制此文件为 .env 并修改相应值

# 服务器配置
HOST=0.0.0.0
PORT=8080
DEBUG=False

# 外部访问地址(TVBox客户端使用)
# 设置为您的局域网IP或公网域名
EXTERNAL_HOST=http://192.168.0.88:8080

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 数据源配置更新间隔(小时)
SOURCE_UPDATE_INTERVAL=6

# 缓存配置
CACHE_ENABLED=True
CACHE_TTL=3600
