# TVSource Studio - 环境配置模板
# 复制此文件为 .env 并修改相应配置

# ==================== 外部访问地址 ====================
# Flask服务的外部访问地址（TVBox需要访问的地址）
# 请修改为您的机器实际IP地址
# 示例: http://192.168.0.88:8080
EXTERNAL_HOST=http://192.168.0.88:8080

# ==================== Flask服务配置 ====================
# 监听地址（0.0.0.0表示所有网络接口）
FLASK_HOST=0.0.0.0
# 监听端口
FLASK_PORT=8080
# 调试模式（生产环境设为False）
FLASK_DEBUG=False

# ==================== 数据更新配置 ====================
# 源数据更新间隔（小时）
UPDATE_INTERVAL=6

# ==================== 日志配置 ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==================== 缓存配置 ====================
# SQLite缓存有效期（秒），默认3600秒（1小时）
CACHE_TTL=3600
